CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=flights
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
RYANAIR_ORIGINS=STN,DUB,BGY,CRL,BVA,BCN,MAD,FCO
RYANAIR_CORRELATION_ID=00000000-0000-0000-0000-000000000000

# Trigger.dev secret key. Required by `src/frontend/server.ts` to call
# `tasks.trigger()` from outside the trigger.dev runtime. Get it from
# https://cloud.trigger.dev → your project → API Keys. Keys are scoped:
#   - `tr_dev_*` for the dev environment
#   - `tr_prod_*` for the prod environment
# Never commit this — keep `.env` out of git (it's already gitignored).
TRIGGER_SECRET_KEY=
# `xid=...` session token Ryanair issues per browser session. The booking
# availability API rejects requests without it with `409 Availability
# declined` regardless of any ToU consent cookies. Open
# https://www.ryanair.com/gb/en in a browser, then copy the `xid` value
# from devtools → Application → Cookies. Note: it expires — re-grab when
# the API starts returning 409 again.
# Example: RYANAIR_XID_COOKIE=xid=fa65ac78-d92e-4b25-91f4-78381f187054
RYANAIR_XID_COOKIE=

# ----- OpenTelemetry / ClickStack -----
# Set to 0 to disable the in-process OTel emitters (logs/spans/metrics stop
# being written to ClickHouse). Defaults to 1.
OTEL_ENABLE=1
# The value emitted as the OTel `service.name` resource attribute. ClickStack
# surfaces this in the HyperDX service picker.
OTEL_SERVICE_NAME=hackathron-crawler
# When you point ClickStack at a different ClickHouse database (the
# ClickStack OTel collector image picks the target DB via
# HYPERDX_OTEL_EXPORTER_CLICKHOUSE_DATABASE), make sure it matches
# CLICKHOUSE_DATABASE above so the otel_* tables exist there.

# ----- Crawl rate limits (see src/config/crawl.ts) -----
# Min ms between two requests within a single crawler. Defaults: Ryanair 20000,
# EasyJet 20000. Combine with `concurrencyLimit: 1` on the route task to keep
# the effective global rate to one request per `requestDelayMs` (+jitter).
CRAWL_RYANAIR_REQUEST_DELAY_MS=20000
CRAWL_RYANAIR_REQUEST_JITTER_MS=10000
# Skip re-fetching a destination that was crawled within this window. 0 = always re-fetch.
CRAWL_RYANAIR_COOLDOWN_MS=0
CRAWL_RYANAIR_ADULTS=1

CRAWL_EASYJET_REQUEST_DELAY_MS=20000
CRAWL_EASYJET_REQUEST_JITTER_MS=10000
CRAWL_EASYJET_COOLDOWN_MS=0
CRAWL_EASYJET_ADULTS=1
