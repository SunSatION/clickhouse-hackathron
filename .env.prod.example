# Production env for the Wayfare frontend (Vercel / VPS).
#
# This file documents every variable the running Express server needs in
# production. Copy it to `.env` on the host (or paste each value into the
# Vercel project → Settings → Environment Variables).
#
# Everything below `RYANAIR_XID_COOKIE` is required. Do NOT set
# `TRIGGER_SECRET_KEY` here unless you also generate a *prod* key from the
# Trigger dashboard — the dev `tr_dev_…` key only works in the dev env.

# --- ClickHouse ---
CLICKHOUSE_URL=http://your-clickhouse-host:8123
CLICKHOUSE_DATABASE=flights
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

# --- OTel / ClickStack ---
OTEL_ENABLE=1
OTEL_DATABASE=otel
OTEL_SERVICE_NAME=hackathron-crawler
# Optional: URL the dashboard displays for "Open HyperDX".
HYPERDX_URL=https://hyperdx.example.com

# --- Ryanair auth ---
RYANAIR_CORRELATION_ID=
RYANAIR_XID_COOKIE=
# Comma-separated IATAs. Keep small on the Free plan; full list ≈ 199 origins
# which would consume the $5/mo credit in a single scan.
RYANAIR_ORIGINS=STN,DUB,BGY,CRL,BVA,BCN,MAD,FCO

# --- Crawl pacing (must keep defaults per AGENTS.md Decision #2) ---
CRAWL_RYANAIR_REQUEST_DELAY_MS=20000
CRAWL_RYANAIR_REQUEST_JITTER_MS=10000
CRAWL_RYANAIR_COOLDOWN_MS=0
CRAWL_RYANAIR_ADULTS=1
CRAWL_EASYJET_REQUEST_DELAY_MS=20000
CRAWL_EASYJET_REQUEST_JITTER_MS=10000
CRAWL_EASYJET_COOLDOWN_MS=0
CRAWL_EASYJET_ADULTS=1

# --- LLM (hosted; no per-user key) ---
OPENAI_API_KEY=
# Optional override; defaults to gpt-4o-mini on the server.
OPENAI_MODEL=gpt-4o-mini

# --- Trigger.dev (frontend → Trigger) ---
# Prod access token from the Trigger dashboard. The dev `tr_dev_…` token will
# trigger against the dev env only.
TRIGGER_SECRET_KEY=tr_prod_

# --- Server ---
PORT=3030
FRONTEND_PORT=3030
